
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local imageId = "rbxassetid://110539296440682"

local function showImageToAll()
    for _, p in pairs(Players:GetPlayers()) do
        local existing = p.PlayerGui:FindFirstChild("FrinImageGui")
        if existing then existing:Destroy() end

        local screenGui = Instance.new("ScreenGui")
        screenGui.ResetOnSpawn = false
        screenGui.Name = "FrinImageGui"
        screenGui.Parent = p.PlayerGui

        -- 이미지 꽉차게
        local image = Instance.new("ImageLabel")
        image.Image = "rbxassetid://110539296440682"
        image.Size = UDim2.new(1, 0, 1, 0)
        image.Position = UDim2.new(0, 0, 0, 0)
        image.BackgroundTransparency = 1
        image.ZIndex = 10
        image.Parent = screenGui

        -- 디스코드 링크 하단에
        local discord = Instance.new("TextLabel")
        discord.Size = UDim2.new(1, 0, 0, 50)
        discord.Position = UDim2.new(0, 0, 1, -50)
        discord.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
        discord.TextColor3 = Color3.fromRGB(255, 255, 255)
        discord.Text = "discord.gg/YvrABMSRZ"
        discord.TextSize = 24
        discord.Font = Enum.Font.GothamBold
        discord.BorderSizePixel = 0
        discord.ZIndex = 11
        discord.Parent = screenGui
    end
end

local function createUI(player)
    local screenGui = Instance.new("ScreenGui")
    screenGui.ResetOnSpawn = false
    screenGui.Parent = player.PlayerGui

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 380, 0, 280)
    frame.Position = UDim2.new(0.5, -190, 0.5, -140)
    frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    frame.Active = true
    frame.Draggable = true
    frame.Parent = screenGui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = frame

    local titleBar = Instance.new("Frame")
    titleBar.Size = UDim2.new(1, 0, 0, 45)
    titleBar.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    titleBar.BorderSizePixel = 0
    titleBar.Parent = frame

    local titleCorner = Instance.new("UICorner")
    titleCorner.CornerRadius = UDim.new(0, 10)
    titleCorner.Parent = titleBar

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 1, 0)
    title.BackgroundTransparency = 1
    title.Text = "FRIN TEAM HUB"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextSize = 20
    title.Font = Enum.Font.GothamBold
    title.Parent = titleBar

    local line = Instance.new("Frame")
    line.Size = UDim2.new(1, -20, 0, 1)
    line.Position = UDim2.new(0, 10, 0, 45)
    line.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    line.BorderSizePixel = 0
    line.Parent = frame

    local grid = Instance.new("Frame")
    grid.Size = UDim2.new(1, -20, 1, -60)
    grid.Position = UDim2.new(0, 10, 0, 52)
    grid.BackgroundTransparency = 1
    grid.Parent = frame

    local uiGrid = Instance.new("UIGridLayout")
    uiGrid.CellSize = UDim2.new(0.31, -4, 0.28, -4)
    uiGrid.CellPadding = UDim2.new(0, 6, 0, 6)
    uiGrid.Parent = grid

    local hintThread = nil

    local buttons = {
        {"Decal", function()
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Decal") or obj:IsA("Texture") then obj:Destroy() end
            end
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") then
                    for _, face in pairs(Enum.NormalId:GetEnumItems()) do
                        local decal = Instance.new("Decal")
                        decal.Texture = imageId
                        decal.Face = face
                        decal.Parent = obj
                    end
                end
            end
        end},

        {"Skybox", function()
            for _, child in pairs(Lighting:GetChildren()) do
                if child:IsA("Sky") then child:Destroy() end
            end
            local sky = Instance.new("Sky")
            sky.SkyboxBk = imageId
            sky.SkyboxDn = imageId
            sky.SkyboxFt = imageId
            sky.SkyboxLf = imageId
            sky.SkyboxRt = imageId
            sky.SkyboxUp = imageId
            sky.Parent = Lighting
        end},

        {"Hint", function()
            if hintThread then task.cancel(hintThread) end
            hintThread = task.spawn(function()
                local hint = Instance.new("Hint")
                hint.Text = "FRIN TEAM ON TOP https://discord.gg/YvrABMSRZ"
                while true do
                    hint.Parent = workspace
                    task.wait(15)
                    hint:Remove()
                    task.wait(30)
                end
            end)
        end},

        {"Particle", function()
            for _, p in pairs(Players:GetPlayers()) do
                local character = p.Character
                if not character then continue end
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                if not rootPart then continue end
                for _, obj in pairs(rootPart:GetChildren()) do
                    if obj:IsA("ParticleEmitter") then obj:Destroy() end
                end
                local particle = Instance.new("ParticleEmitter")
                particle.Texture = imageId
                particle.Rate = 50
                particle.Lifetime = NumberRange.new(1, 3)
                particle.Speed = NumberRange.new(5, 10)
                particle.Size = NumberSequence.new(1, 3)
                particle.Parent = rootPart
            end
        end},

        {"Kill All", function()
            for _, p in pairs(Players:GetPlayers()) do
                if p.UserId ~= player.UserId then
                    local character = p.Character
                    if not character then continue end
                    local humanoid = character:FindFirstChild("Humanoid")
                    if humanoid then humanoid.Health = 0 end
                end
            end
        end},

        {"폭발", function()
            for _, p in pairs(Players:GetPlayers()) do
                if p.UserId ~= player.UserId then
                    local character = p.Character
                    if not character then continue end
                    local rootPart = character:FindFirstChild("HumanoidRootPart")
                    if not rootPart then continue end
                    local explosion = Instance.new("Explosion")
                    explosion.Position = rootPart.Position
                    explosion.BlastRadius = 15
                    explosion.BlastPressure = 999999
                    explosion.DestroyJointRadiusPercent = 0
                    explosion.Parent = workspace
                end
            end
        end},

        {"화면 도배", function()
            showImageToAll()
        end},

        {"Kick All", function()
            for _, p in pairs(Players:GetPlayers()) do
                if p.UserId ~= player.UserId then
                    p:Kick("You lost to the FRIN TEAM.")
                end
            end
        end},
    }

    for _, data in pairs(buttons) do
        local btn = Instance.new("TextButton")
        btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        btn.TextColor3 = Color3.fromRGB(220, 220, 220)
        btn.Text = data[1]
        btn.TextSize = 14
        btn.Font = Enum.Font.GothamBold
        btn.BorderSizePixel = 0
        btn.Parent = grid

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = btn

        btn.MouseButton1Click:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
            task.wait(0.15)
            btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            data[2]()
        end)

        btn.MouseEnter:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
        end)
        btn.MouseLeave:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        end)
    end
end

for _, player in pairs(Players:GetPlayers()) do
    createUI(player)
end

Players.PlayerAdded:Connect(function(player)
    createUI(player)
end)
